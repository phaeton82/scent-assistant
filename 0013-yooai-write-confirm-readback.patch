From 25147f241a23b899fd5f3cc7d89c13880d0f6af7 Mon Sep 17 00:00:00 2001
From: temp <temp@temp.com>
Date: Sat, 4 Jul 2026 19:05:09 +0000
Subject: [PATCH] Confirm Yooai schedule writes by reading back after a short
 delay
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Setting a time/duration/day was showing the optimistic local value
immediately, which could then 'jump back' once a later read (the
periodic poll, or the next connect) caught the device's real,
possibly-still-old state if the write hadn't fully landed yet. Now
every schedule write is followed by: wait 1s, send the 0x08 query,
wait 0.5s for the response, then notify HA — so the displayed value
is always the device's own confirmed state, not just what we assumed
we wrote.
---
 custom_components/scent_assistant/device.py | 15 +++++++++++++++
 1 file changed, 15 insertions(+)

diff --git a/custom_components/scent_assistant/device.py b/custom_components/scent_assistant/device.py
index e09c18b..b7fe471 100644
--- a/custom_components/scent_assistant/device.py
+++ b/custom_components/scent_assistant/device.py
@@ -1120,6 +1120,21 @@ class ScentDiffuserDevice:
                 )
 
             if cmd and await self._ble_execute(cmd):
+                if isinstance(self._protocol, YooaiBleProtocol):
+                    # Confirm the write actually landed by reading the
+                    # schedule back, instead of trusting our own optimistic
+                    # local values — the device needs a moment to process
+                    # a write before its read-back reflects it, so a
+                    # confirmed value only exists after this round-trip.
+                    await asyncio.sleep(1.0)
+                    try:
+                        await self._ble_send(self._protocol.build_query())
+                        await asyncio.sleep(0.5)
+                    except (BleakError, asyncio.TimeoutError, OSError) as err:
+                        _LOGGER.debug(
+                            "Yooai post-write confirmation read failed on %s: %s",
+                            self._ble_name, err,
+                        )
                 self._notify_state_changed()
                 return True
 
